# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GoHighLevel webhook URL — paste your GHL inbound webhook here
GHL_WEBHOOK_URL=https://hooks.leadconnectorhq.com/hooks/your-webhook-id

# Optional: site URL (used for auth redirects on Vercel)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
